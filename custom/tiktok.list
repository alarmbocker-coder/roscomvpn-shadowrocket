# =====================================================================
# TikTok / ByteDance
# Пользовательский список. Подключается в roscomvpn.conf как RULE-SET
# выше DIRECT/GEOIP, чтобы TikTok всегда шёл через VPN.
# =====================================================================

# --- Жёсткий перехват TikTok / ByteDance по ключевым словам ---
DOMAIN-KEYWORD,tiktok
DOMAIN-KEYWORD,tiktokcdn
DOMAIN-KEYWORD,tiktokv
DOMAIN-KEYWORD,tiktokw
DOMAIN-KEYWORD,tiktokrow
DOMAIN-KEYWORD,byteoversea
DOMAIN-KEYWORD,byteoverseas
DOMAIN-KEYWORD,bytedance
DOMAIN-KEYWORD,byteimg
DOMAIN-KEYWORD,ibyteimg
DOMAIN-KEYWORD,ibytedtos
DOMAIN-KEYWORD,muscdn
DOMAIN-KEYWORD,snssdk
DOMAIN-KEYWORD,isnssdk
DOMAIN-KEYWORD,pstatp
DOMAIN-KEYWORD,sgpstatp
DOMAIN-KEYWORD,amemv

# --- Основные домены TikTok ---
DOMAIN-SUFFIX,tiktok.com
DOMAIN-SUFFIX,tiktokv.com
DOMAIN-SUFFIX,tiktokv.eu
DOMAIN-SUFFIX,tiktokv.us
DOMAIN-SUFFIX,tiktokw.eu
DOMAIN-SUFFIX,tiktokw.us
DOMAIN-SUFFIX,tiktokcdn.com
DOMAIN-SUFFIX,tiktokcdn-us.com
DOMAIN-SUFFIX,tiktokcdn-eu.com
DOMAIN-SUFFIX,tiktokd.net
DOMAIN-SUFFIX,tiktokd.org
DOMAIN-SUFFIX,tiktok-row.net
DOMAIN-SUFFIX,tiktokrow-cdn.com
DOMAIN-SUFFIX,tiktokeu-cdn.com
DOMAIN-SUFFIX,tiktok-minis.com
DOMAIN-SUFFIX,tiktokminis.us
DOMAIN-SUFFIX,tiktokglobalshopv.com
DOMAIN-SUFFIX,tik-tokapi.com

# --- Live / CDN / статика ---
DOMAIN-SUFFIX,ttlivecdn.com
DOMAIN-SUFFIX,ttwstatic.com
DOMAIN-SUFFIX,ttcdn-us.com
DOMAIN-SUFFIX,ttoverseaus.net
DOMAIN-SUFFIX,muscdn.com
DOMAIN-SUFFIX,musical.ly

# --- ByteDance / media / object storage ---
DOMAIN-SUFFIX,byteoversea.com
DOMAIN-SUFFIX,byteoversea.net
DOMAIN-SUFFIX,byteoversea.org
DOMAIN-SUFFIX,byteoverseas.com
DOMAIN-SUFFIX,byteimg.com
DOMAIN-SUFFIX,ibyteimg.com
DOMAIN-SUFFIX,ibytedtos.com
DOMAIN-SUFFIX,bytedapm.com
DOMAIN-SUFFIX,bytefcdn-oversea.com
DOMAIN-SUFFIX,bytegecko.com
DOMAIN-SUFFIX,bytegecko-i18n.com

# --- SDK / аналитика / служебные API ---
DOMAIN-SUFFIX,snssdk.com
DOMAIN-SUFFIX,isnssdk.com
DOMAIN-SUFFIX,sgpstatp.com
DOMAIN-SUFFIX,ipstatp.com
DOMAIN-SUFFIX,amemv.com
DOMAIN-SUFFIX,appsflyer.com
DOMAIN-SUFFIX,appsflyersdk.com
DOMAIN-SUFFIX,adjust.com
DOMAIN-SUFFIX,bdurl.net
DOMAIN-SUFFIX,toutiao.com

# --- Явные TikTok-хосты и edge/CDN ---
DOMAIN,analytics.tiktok.com
DOMAIN,api.tiktokv.com
DOMAIN,tiktokcdn.com.akamaized.net
DOMAIN,tiktokcdn.com.edgesuite.net
DOMAIN,tiktokcdn-us.com.edgesuite.net
DOMAIN,tiktokv.com.edgekey.net
DOMAIN,tiktokv.com.edgesuite.net
DOMAIN,p16-tiktokcdn-com.akamaized.net
DOMAIN,roovza-launches.appsflyersdk.com
DOMAIN,roovza.inapps.appsflyersdk.com
DOMAIN,roovza.launches.appsflyersdk.com
DOMAIN,roovza.skadsdk.appsflyersdk.com

# --- Частые RU/региональные TikTok API, которые не должны уходить в GEOIP,RU,DIRECT ---
DOMAIN-SUFFIX,ycru.tiktokv.com
DOMAIN-SUFFIX,alisg.tiktokv.com
DOMAIN-SUFFIX,useast1a.tiktokv.com
DOMAIN-SUFFIX,useast5.us.tiktokv.com
